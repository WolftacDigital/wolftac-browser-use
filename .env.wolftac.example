# Wolftac-safe Browser Use defaults
ANONYMIZED_TELEMETRY=false
BROWSER_USE_CLOUD_SYNC=false
BROWSER_USE_LOGGING_LEVEL=warning
BROWSER_USE_SETUP_LOGGING=false

# Keep config/cache local to this adapted repo by default.
# The wrapper exports these automatically; set manually only if needed.
# BROWSER_USE_HOME=./.wolftac/browser-use-home
# BROWSER_USE_CONFIG_DIR=./.wolftac/browseruse-config

# Optional model/cloud keys. Do not commit real values.
# BROWSER_USE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
